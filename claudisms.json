{
  "version": "2026-06-30",
  "source": "https://www.boobridge.com/claudisms/",
  "description": "Banlist of words, phrases, and structural tics that signal AI-generated writing. Used by the Claudisms Chrome extension to flag/hide/rewrite LinkedIn content.",
  "matchTypes": {
    "literal": "case-insensitive substring match against 'match' strings",
    "regex": "case-insensitive regex in 'pattern' (may use unicode escapes)",
    "manual": "judgment-based tic with no reliable automatic match; for guidance only"
  },
