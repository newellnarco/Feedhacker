{
  "manifest_version": 3,
  "name": "FeedHacker",
  "version": "0.1.0",
  "description": "Mute the noise in your LinkedIn feed — AI slop, promoted posts, engagement-bait reshares, newsletter funnels, hiring, and more — with a Mute/Solo mixer.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "filters.js",
        "logger.js",
        "matcher.js",
        "scorer.js",
        "feed.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "claudisms.json"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FeedHacker",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
