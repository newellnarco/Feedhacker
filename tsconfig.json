{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "none",
    "rootDir": "src",
    "outDir": "build",
    "strict": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "removeComments": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "newLine": "lf"
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts"]
}
